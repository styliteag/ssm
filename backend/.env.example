# SSM backend configuration — copy to `.env` and edit.
#
# Every setting is read straight from the environment. Variables already
# exported in your shell win over values written here. To point at a
# different file, set DOTENV=/path/to/file.env.

# --- core ---------------------------------------------------------------
# SQLAlchemy database URL. Default: sqlite:///ssm.db
# DATABASE_URL=sqlite:///ssm.db

# JWT signing secret (32+ chars). Required in production.
# Generate one with: openssl rand -hex 32
# JWT_SECRET=replace-me-with-a-long-random-string

# Path to the htpasswd credentials file (auto-created if missing).
# HTPASSWD=.htpasswd

# Logging level: trace, debug, info, warn, error.
# LOGLEVEL=info

# Listen address + port for uvicorn.
# LISTEN=::
# PORT=8000

# --- ssh ----------------------------------------------------------------
# Path to the SSH private key used to connect to managed hosts.
# SSH_KEY=keys/id_ssm

# Optional passphrase for the SSH private key.
# SSH_KEY_PASSPHRASE=

# SSH connection timeout in seconds.
# SSH_TIMEOUT=120

# Optional cron-style schedules for background jobs.
# SSH_CHECK_SCHEDULE=
# SSH_UPDATE_SCHEDULE=
